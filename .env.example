# OpenRouter API key (обязательно)
# Получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Режимы multi-model solver для задач по фото: cheap | accurate
PHOTO_SOLVER_MODE=cheap

# Асимметричная тройка моделей для решения всех задач.
# Qwen = parser, Kimi = main solver, Llama = verifier.
PHOTO_SOLVER_KIMI_MODEL=moonshotai/kimi-k2.6
PHOTO_SOLVER_QWEN_MODEL=qwen/qwen2.5-vl-72b-instruct
PHOTO_SOLVER_LLAMA_MODEL=meta-llama/llama-4-maverick

# Хоткей для переключения окна чата (показать / скрыть)
# Формат pynput: <ctrl>+<space>, <alt>+z и т.д.
HOTKEY_WINDOW=<ctrl>+<space>

# Хоткей только для показа окна (если скрыто — показать; если уже видно — ничего)
HOTKEY_SHOW=<ctrl>+<shift>+<space>

# Хоткей для фонового запроса (берёт содержимое буфера, отправляет, записывает ответ)
HOTKEY_CLIPBOARD=<ctrl>+<alt>+<space>
