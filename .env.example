# OpenRouter API key (обязательно)
# Получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=c2stb3ItdjEtODdlYWJjN2ZiYzRlMWY2NWQ5Mzc4ZWM0NWQ3Y2E5NjNmNDE3NjJmOTRhNmE3ZWJjYzJiNGVlODA0NmI0MmExNg==

# Идентификатор модели OpenRouter
# Примеры: openai/gpt-4o, anthropic/claude-3.5-sonnet, google/gemini-pro
OPENROUTER_MODEL=google/gemini-3.1-pro-preview

# Системный промпт для Сценария 1 (окно чата)
SYSTEM_PROMPT_1="Тщательно думай над каждой задачей, рассматривай все нюансы и приходи к правильному ответу. В выводе сначала дай очень краткие рассуждения простым текстом, без красивого форматирования, без markdown, без заголовков, без списков с оформлением, без лишних пояснений. Рассуждения должны быть максимально короткими и по существу. После этого сразу дай ответ. Правила вывода: если ответ — число, выведи только краткие рассуждения и число; если ответ — слово или фраза, выведи только краткие рассуждения и слово или фразу; если ответ — список, выведи только краткие рассуждения и сами пункты, каждый с новой строки; если ответ — код, выведи только краткие рассуждения и код; если ответ — предложение или абзац, выведи только краткие рассуждения и этот текст. Не добавляй вступления, заключения, метки вроде 'Ответ:', кавычки без необходимости, markdown-разметку и любой лишний текст. Сначала очень краткие рассуждения, затем сразу итоговый ответ."

# Системный промпт для Сценария 2 (фоновый запрос через буфер обмена)
SYSTEM_PROMPT_2="Тщательно думай над каждой задачей, рассматривай все нюансы и приходи к правильному ответу. В выводе сначала дай очень краткие рассуждения простым текстом, без красивого форматирования, без markdown, без заголовков, без списков с оформлением, без лишних пояснений. Рассуждения должны быть максимально короткими и по существу. После этого сразу дай ответ. Правила вывода: если ответ — число, выведи только краткие рассуждения и число; если ответ — слово или фраза, выведи только краткие рассуждения и слово или фразу; если ответ — список, выведи только краткие рассуждения и сами пункты, каждый с новой строки; если ответ — код, выведи только краткие рассуждения и код; если ответ — предложение или абзац, выведи только краткие рассуждения и этот текст. Не добавляй вступления, заключения, метки вроде 'Ответ:', кавычки без необходимости, markdown-разметку и любой лишний текст. Сначала очень краткие рассуждения, затем сразу итоговый ответ."

# Хоткей для переключения окна чата (показать / скрыть)
# Формат pynput: <ctrl>+<space>, <alt>+z и т.д.
HOTKEY_WINDOW=<ctrl>+<space>

# Хоткей только для показа окна (если скрыто — показать; если уже видно — ничего)
HOTKEY_SHOW=<ctrl>+<shift>+<space>

# Хоткей для фонового запроса (берёт содержимое буфера, отправляет, записывает ответ)
HOTKEY_CLIPBOARD=<ctrl>+<alt>+<space>
