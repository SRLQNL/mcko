# OpenRouter API key (обязательно)
# Получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модели. Используются роли: Qwen=парсер/OCR, Kimi=основной решатель, Llama=верификатор.
# По умолчанию выбраны модели, которые:
#   1. Работают без response_format (решает проблему в школьных сетях)
#   2. Доступны без принятия отдельного ToS провайдера
#   3. Хорошо решают задачи ЕГЭ/ОГЭ/МЦКО на русском
#
# Если модель возвращает 403 — зайди на openrouter.ai/models, найди модель
# и прими Terms of Service провайдера (Google, OpenAI, Anthropic требуют это).
#
PHOTO_SOLVER_KIMI_MODEL=deepseek/deepseek-chat-v3-0324
PHOTO_SOLVER_QWEN_MODEL=qwen/qwen2.5-vl-72b-instruct
PHOTO_SOLVER_LLAMA_MODEL=moonshotai/kimi-k2

# Хоткей для переключения окна чата (показать / скрыть)
HOTKEY_WINDOW=<ctrl>+<space>

# Хоткей только для показа окна
HOTKEY_SHOW=<ctrl>+<shift>+<space>

# Хоткей для фонового запроса (берёт содержимое буфера, отправляет, записывает ответ)
HOTKEY_CLIPBOARD=<ctrl>+<alt>+<space>

# Хоткей для создания скриншота и вставки его в поле ввода
HOTKEY_SCREENSHOT=<ctrl>+<shift>+s
