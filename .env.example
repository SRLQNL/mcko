# OpenRouter API key (обязательно)
# Получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Идентификатор модели OpenRouter
# Примеры: openai/gpt-4.1-mini, moonshotai/kimi-k2, google/gemini-2.5-flash
# Если оставить пустым и не задать OPENROUTER_MODELS, text-only чат будет отключен.
OPENROUTER_MODEL=

# Необязательный пул моделей OpenRouter в порядке приоритета
# Пример:
# OPENROUTER_MODELS=qwen/qwen2.5-vl-72b-instruct,meta-llama/llama-4-maverick,google/gemma-4-31b-it
OPENROUTER_MODELS=

# Режимы multi-model solver для задач по фото: cheap | accurate
PHOTO_SOLVER_MODE=cheap

# Асимметричная тройка моделей для geometry/photo solver
PHOTO_SOLVER_KIMI_MODEL=moonshotai/kimi-k2.6
PHOTO_SOLVER_QWEN_MODEL=qwen/qwen2.5-vl-72b-instruct
PHOTO_SOLVER_LLAMA_MODEL=meta-llama/llama-4-maverick

# Системный промпт для Сценария 1 (окно чата)
SYSTEM_PROMPT_1="Тщательно решай задачу и приходи к правильному ответу. В выводе не пиши объяснения, рассуждения, вступления, комментарии, markdown, заголовки, метки вроде 'Ответ:' и любой лишний текст. Выводи только итоговые ответы в формате нумерованного списка. Каждый пункт должен быть строго в виде: 1) Ответ 2) Ответ 3) Ответ. Если ответ один, выведи только одну строку: 1) Ответ. Если ответов несколько, выведи каждый ответ с новой строки в таком же формате. Ничего не добавляй до или после списка."

# Системный промпт для Сценария 2 (фоновый запрос через буфер обмена)
SYSTEM_PROMPT_2="Тщательно решай задачу и приходи к правильному ответу. В выводе не пиши объяснения, рассуждения, вступления, комментарии, markdown, заголовки, метки вроде 'Ответ:' и любой лишний текст. Выводи только итоговые ответы в формате нумерованного списка. Каждый пункт должен быть строго в виде: 1) Ответ 2) Ответ 3) Ответ. Если ответ один, выведи только одну строку: 1) Ответ. Если ответов несколько, выведи каждый ответ с новой строки в таком же формате. Ничего не добавляй до или после списка."

# Хоткей для переключения окна чата (показать / скрыть)
# Формат pynput: <ctrl>+<space>, <alt>+z и т.д.
HOTKEY_WINDOW=<ctrl>+<space>

# Хоткей только для показа окна (если скрыто — показать; если уже видно — ничего)
HOTKEY_SHOW=<ctrl>+<shift>+<space>

# Хоткей для фонового запроса (берёт содержимое буфера, отправляет, записывает ответ)
HOTKEY_CLIPBOARD=<ctrl>+<alt>+<space>
