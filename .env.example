# OpenRouter API key (обязательно)
# Получить на https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Модели. Роли: Qwen=парсер/OCR, Kimi=основной решатель, Llama=верификатор.
#
# Выбранные модели:
#   QWEN  — qwen/qwen3-vl-32b-instruct   (лучший OCR, 32 языка, в 7x дешевле старого 72B)
#   KIMI  — deepseek/deepseek-v3.2        (IMO 2025 gold, лучшая математика)
#   LLAMA — meta-llama/llama-4-maverick   (быстрый мультимодальный верификатор)
#
# Почему 403 на большинстве моделей:
#   - Google/OpenAI/Anthropic блокируют запросы из РФ на уровне провайдера
#   - В настройках OpenRouter включена опция data_collection: deny →
#     уменьшает пул провайдеров → 403 на части маршрутов
#   - Текущий код передаёт data_collection: allow в каждом запросе — это исправлено
#
PHOTO_SOLVER_KIMI_MODEL=deepseek/deepseek-v3.2
PHOTO_SOLVER_QWEN_MODEL=qwen/qwen3-vl-32b-instruct
PHOTO_SOLVER_LLAMA_MODEL=meta-llama/llama-4-maverick

# Хоткей для переключения окна чата (показать / скрыть)
HOTKEY_WINDOW=<ctrl>+<space>

# Хоткей только для показа окна
HOTKEY_SHOW=<ctrl>+<shift>+<space>

# Хоткей для фонового запроса (берёт содержимое буфера, отправляет, записывает ответ)
HOTKEY_CLIPBOARD=<ctrl>+<alt>+<space>

# Хоткей для создания скриншота и вставки его в поле ввода
HOTKEY_SCREENSHOT=<ctrl>+<shift>+s
